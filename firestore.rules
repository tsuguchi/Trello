rules_version = '2';

// ========================================
// 開発用ルール（Phase 1 開発中）
// ========================================
// ログイン済みユーザーなら全データを読み書き可能。
// Phase 1 完成後、下の「本番用ルール」に差し替える。
//
// このルールを Firebase Console の
// Firestore Database > ルール タブに貼り付けて「公開」する。
// ========================================

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

